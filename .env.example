# ──────────────────────────────────────────────────────────────
# FitZone Gym — Environment Variables (template)
# Copy to `.env.local` and fill in real values. Never commit secrets.
# Path B: static export + Supabase backend.
# ──────────────────────────────────────────────────────────────

# Supabase (Phase 3) — public values, safe to expose in the static client.
# The anon key is protected by Row-Level-Security policies on the DB.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WhatsApp click-to-chat number in international format, digits only
# e.g. 14155551234  (used to build https://wa.me/<number>)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Public phone number for click-to-call (tel:) — display + dial
NEXT_PUBLIC_PHONE_NUMBER=

# Google Maps embed (Phase 4) — public embed URL/place
NEXT_PUBLIC_GMAPS_EMBED_URL=

# Google Analytics 4 (Phase 4)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Public site URL (used for sitemap.xml / robots.txt / Open Graph)
# e.g. https://www.fitzonegym.com
NEXT_PUBLIC_SITE_URL=

# Resend API key — used ONLY by the Supabase Edge Function (server side),
# not by the static client. Set this in the Supabase dashboard, not here.
# RESEND_API_KEY=
